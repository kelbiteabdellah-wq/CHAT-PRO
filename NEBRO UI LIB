function NEBROLIB.createDropdown(parent, options, defaultIndex, callback)
	options = options or {}
	local box = createExampleBox(parent, 60)

	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(1, 0, 0, 34)
	btn.BackgroundColor3 = Theme.BG
	btn.BorderSizePixel = 0
	btn.TextColor3 = Theme.Text
	btn.Font = Enum.Font.Gotham
	btn.TextSize = 15
	btn.Parent = box
	corner(btn, UDim.new(0, 8))
	stroke(btn, 1.2, Theme.Accent, 0.2)

	local selected = options[defaultIndex or 1] or options[1] or "None"
	btn.Text = selected

	local open = false
	local dropFrame = Instance.new("Frame")
	dropFrame.Position = UDim2.new(0, 0, 1, 4)
	dropFrame.Size = UDim2.new(1, 0, 0, 0)
	dropFrame.BackgroundColor3 = Theme.BG
	dropFrame.BorderSizePixel = 0
	dropFrame.Visible = false
	dropFrame.Parent = box
	corner(dropFrame, UDim.new(0, 8))
	stroke(dropFrame, 1.2, Theme.Accent, 0.2)

	local dropScroll = Instance.new("ScrollingFrame")
	dropScroll.BackgroundTransparency = 1
	dropScroll.Size = UDim2.new(1, 0, 1, 0)
	dropScroll.ScrollBarThickness = 5
	dropScroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
	dropScroll.CanvasSize = UDim2.new(0, 0, 0, 0)
	dropScroll.Parent = dropFrame

	local dropList = Instance.new("UIListLayout")
	dropList.Padding = UDim.new(0, 4)
	dropList.SortOrder = Enum.SortOrder.LayoutOrder
	dropList.Parent = dropScroll

	local dropPad = padding(dropScroll, 6, 6, 6, 6)

	local function refreshHeight()
		local h = math.clamp(#options * 32 + 12, 36, 190)
		dropFrame.Size = UDim2.new(1, 0, 0, h)
		dropScroll.CanvasSize = UDim2.new(0, 0, 0, #options * 34 + 8)
	end

	for _, opt in ipairs(options) do
		local optBtn = Instance.new("TextButton")
		optBtn.Size = UDim2.new(1, 0, 0, 28)
		optBtn.BackgroundColor3 = Theme.Panel2
		optBtn.BorderSizePixel = 0
		optBtn.Text = tostring(opt)
		optBtn.TextColor3 = Theme.Text
		optBtn.Font = Enum.Font.Gotham
		optBtn.TextSize = 14
		optBtn.Parent = dropScroll
		corner(optBtn, UDim.new(0, 6))
		stroke(optBtn, 1, Theme.Accent, 0.45)

		optBtn.MouseButton1Click:Connect(function()
			selected = opt
			btn.Text = tostring(opt)
			open = false
			dropFrame.Visible = false
			if callback then
				callback(opt)
			end
		end)
	end

	refreshHeight()

	btn.MouseButton1Click:Connect(function()
		open = not open
		dropFrame.Visible = open
	end)

	return box
end

