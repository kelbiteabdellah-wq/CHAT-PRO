local notifCounter = 0
local notifActive = {}

local function pushNotification(text, kind)
	notifCounter -= 1

	local c = Theme.Accent
	if kind == "success" then
		c = Theme.Success
	elseif kind == "error" then
		c = Theme.Error
	elseif kind == "warning" then
		c = Theme.Warning
	elseif kind == "info" then
		c = Theme.Accent
	end

	local notif = Instance.new("Frame")
	notif.Size = UDim2.new(0, 290, 0, 46)
	notif.BackgroundColor3 = Theme.Panel2
	notif.BorderSizePixel = 0
	notif.LayoutOrder = notifCounter
	notif.Parent = notifHolder
	corner(notif, UDim.new(0, 10))
	stroke(notif, 1.5, c, 0.08)

	local accent = Instance.new("Frame")
	accent.Size = UDim2.new(0, 4, 1, -14)
	accent.Position = UDim2.new(0, 10, 0, 7)
	accent.BackgroundColor3 = c
	accent.BorderSizePixel = 0
	accent.Parent = notif
	corner(accent, UDim.new(1, 0))

	local lbl = Instance.new("TextLabel")
	lbl.BackgroundTransparency = 1
	lbl.Position = UDim2.new(0, 22, 0, 0)
	lbl.Size = UDim2.new(1, -32, 1, 0)
	lbl.Font = Enum.Font.GothamBold
	lbl.TextSize = 15
	lbl.TextColor3 = Theme.Text
	lbl.TextXAlignment = Enum.TextXAlignment.Left
	lbl.TextWrapped = true
	lbl.Text = tostring(text)
	lbl.Parent = notif

	table.insert(notifActive, notif)

	task.delay(2.2, function()
		if notif and notif.Parent then
			local info = TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
			TweenService:Create(notif, info, {BackgroundTransparency = 1}):Play()
			TweenService:Create(lbl, info, {TextTransparency = 1}):Play()
			TweenService:Create(accent, info, {BackgroundTransparency = 1}):Play()
			task.wait(0.24)
			if notif then notif:Destroy() end
		end
	end)
end

local minimized = false
local expandedSize = UDim2.new(0, windowConfig.Width, 0, windowConfig.Height)

local function closeAnimation()
	local t = 0.2
	local tween = TweenService:Create(mainFrame, TweenInfo.new(t, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
		Size = UDim2.new(0, 0, 0, 0)
	})
	tween:Play()
	tween.Completed:Wait()
	mainFrame.Visible = false
end

local function setVisible(visible)
	if visible then
		mainFrame.Size = UDim2.new(0, 0, 0, 0)
		mainFrame.Visible = true
		minimized = false
		tabContainer.Visible = true
		pagesContainer.Visible = true
		minBtn.Text = "-"
		TweenService:Create(mainFrame, TweenInfo.new(0.24, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
			Size = expandedSize
		}):Play()
	else
		closeAnimation()
	end
end

