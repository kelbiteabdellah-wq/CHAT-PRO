	local toggle = Instance.new("TextButton")
	toggle.Size = UDim2.new(0, 54, 0, 26)
	toggle.Position = UDim2.new(1, -58, 0.5, -13)
	toggle.BackgroundColor3 = default and Theme.Accent or Theme.Panel2
	toggle.Text = ""
	toggle.BorderSizePixel = 0
	toggle.AutoButtonColor = false
	toggle.Parent = box
	corner(toggle, UDim.new(1, 0))
	stroke(toggle, 1.2, Theme.Accent, 0.15)

	local knob = Instance.new("Frame")
	knob.Size = UDim2.new(0, 22, 0, 22)
	knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
	knob.BorderSizePixel = 0
	knob.Parent = toggle
	corner(knob, UDim.new(1, 0))

	local state = default and true or false
	local function update(animated)
		if state then
			toggle.BackgroundColor3 = Theme.Accent
			if animated then
				knob:TweenPosition(UDim2.new(1, -24, 0.5, -11), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.12, true)
			else
				knob.Position = UDim2.new(1, -24, 0.5, -11)
			end
		else
			toggle.BackgroundColor3 = Theme.Panel2
			if animated then
				knob:TweenPosition(UDim2.new(0, 2, 0.5, -11), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.12, true)
			else
				knob.Position = UDim2.new(0, 2, 0.5, -11)
			end
		end
	end

	toggle.MouseButton1Click:Connect(function()
		state = not state
		update(true)
		if callback then
			callback(state)
		end
	end)

	update(false)
	return box
end

function NEBROLIB.createSlider(parent, labelText, min, max, defaultValue, callback)
	min = tonumber(min) or 0
	max = tonumber(max) or 100
	defaultValue = tonumber(defaultValue) or min

	local box = createExampleBox(parent, 68)

	local topRow = Instance.new("Frame")
	topRow.BackgroundTransparency = 1
	topRow.Size = UDim2.new(1, 0, 0, 18)
	topRow.Parent = box

	local label = Instance.new("TextLabel")
	label.BackgroundTransparency = 1
	label.Size = UDim2.new(1, -56, 1, 0)
	label.Text = tostring(labelText or "Slider")
	label.TextColor3 = Theme.Text
	label.Font = Enum.Font.Gotham
	label.TextSize = 15
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.Parent = topRow

	local valueLabel = Instance.new("TextLabel")
	valueLabel.BackgroundTransparency = 1
	valueLabel.Position = UDim2.new(1, -56, 0, 0)
	valueLabel.Size = UDim2.new(0, 56, 1, 0)
	valueLabel.Text = tostring(defaultValue)
	valueLabel.TextColor3 = Theme.Accent
	valueLabel.Font = Enum.Font.GothamBold
	valueLabel.TextSize = 15
	valueLabel.TextXAlignment = Enum.TextXAlignment.Right
	valueLabel.Parent = topRow

	local bar = Instance.new("Frame")
	bar.Position = UDim2.new(0, 0, 0, 34)
	bar.Size = UDim2.new(1, 0, 0, 12)
	bar.BackgroundColor3 = Theme.Panel2
	bar.BorderSizePixel = 0
	bar.Parent = box
	corner(bar, UDim.new(1, 0))
	stroke(bar, 1, Theme.Accent, 0.25)

	local fill = Instance.new("Frame")
	fill.BackgroundColor3 = Theme.Accent
	fill.BorderSizePixel = 0
	fill.Parent = bar
	corner(fill, UDim.new(1, 0))

	local knob = Instance.new("Frame")
	knob.Size = UDim2.new(0, 18, 0, 18)
	knob.BackgroundColor3 = Theme.Accent
	knob.BorderSizePixel = 0
	knob.Parent = bar
	corner(knob, UDim.new(1, 0))
	stroke(knob, 1, Color3.fromRGB(255, 255, 255), 0.5)

	local dragging = false

	local function setValue(v, fire)
		v = math.clamp(math.floor(v + 0.5), min, max)
		local percent = (v - min) / math.max(1, (max - min))
		fill.Size = UDim2.new(percent, 0, 1, 0)
		knob.Position = UDim2.new(percent, -9, 0.5, -9)
		valueLabel.Text = tostring(v)
		if fire and callback then
			callback(v)
		end
	end

	local function getValueFromX(x)
		local rel = x - bar.AbsolutePosition.X
		local percent = math.clamp(rel / math.max(1, bar.AbsoluteSize.X), 0, 1)
		return min + ((max - min) * percent)
	end

	bar.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			setValue(getValueFromX(input.Position.X), true)
		end
	end)

	knob.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			setValue(getValueFromX(input.Position.X), true)
		end
	end)

	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end)

	setValue(defaultValue, false)
	return box
end

function NEBROLIB.createTextButton(parent, text, callback)
	return NEBROLIB.createButton(parent, text, callback)
end

function NEBROLIB.show()
	setVisible(true)
end

function NEBROLIB.hide()
	closeAnimation()
end

makeDraggable(mainFrame, topBar)
makeDraggable(toggleBtn, toggleBtn)

closeBtn.MouseButton1Click:Connect(function()
	closeAnimation()
end)

minBtn.MouseButton1Click:Connect(function()
	minimized = not minimized
	if minimized then
		tabContainer.Visible = false
		pagesContainer.Visible = false
		minBtn.Text = "+"
		local tween = TweenService:Create(mainFrame, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			Size = UDim2.new(0, windowConfig.Width, 0, 44)
		})
		tween:Play()
	else
		tabContainer.Visible = true
		pagesContainer.Visible = true
		minBtn.Text = "-"
		local tween = TweenService:Create(mainFrame, TweenInfo.new(0.22, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
			Size = expandedSize
		})
		tween:Play()
	end
end)

toggleBtn.MouseButton1Click:Connect(function()
	if mainFrame.Visible then
		closeAnimation()
	else
		minimized = false
		tabContainer.Visible = true
		pagesContainer.Visible = true
		minBtn.Text = "-"
		mainFrame.Size = UDim2.new(0, 0, 0, 0)
		mainFrame.Visible = true
		TweenService:Create(mainFrame, TweenInfo.new(0.24, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
			Size = expandedSize
		}):Play()
	end
end)

NEBROLIB.screenGui = screenGui
NEBROLIB.mainFrame = mainFrame
NEBROLIB.windowConfig = windowConfig

