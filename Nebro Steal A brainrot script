createToggle(ProtectionTab, "الحماية من النحل", false, function(state)
    antiBeeActive = state
    
    local antiBeeConnection = nil
    local defaultFOV = 70
    local blurEffects = {}
    local lastBlurCheck = 0
    local BLUR_CHECK_INTERVAL = 1

    local function findAllBlurEffects()
        local effects = {}
        for _, obj in ipairs(game:GetDescendants()) do
            if obj:IsA("BlurEffect") then
                table.insert(effects, obj)
            end
        end
        return effects
    end

    if state then
        local camera = Workspace.CurrentCamera
        if not camera then return end
        
        defaultFOV = camera.FieldOfView
        blurEffects = findAllBlurEffects()
        
        for _, blur in ipairs(blurEffects) do
            if blur and blur.Parent then
                blur.Enabled = false
            end
        end
        
        antiBeeConnection = RunService.Heartbeat:Connect(function()
            if not antiBeeActive then return end
            
            local now = tick()
            
            if camera.FieldOfView ~= defaultFOV then
                camera.FieldOfView = defaultFOV
            end
            
            for i = #blurEffects, 1, -1 do
                local blur = blurEffects[i]
                if blur and blur.Parent then
                    if blur.Enabled then
                        blur.Enabled = false
                    end
                else
                    table.remove(blurEffects, i)
                end
            end
            
            if now - lastBlurCheck >= BLUR_CHECK_INTERVAL then
                lastBlurCheck = now
                local checkLocations = {
                    game:GetService("Lighting"),
                    camera,
                    LocalPlayer:FindFirstChild("PlayerGui")
                }
                
                for _, location in ipairs(checkLocations) do
                    if location then
                        for _, obj in ipairs(location:GetDescendants()) do
                            if obj:IsA("BlurEffect") and not table.find(blurEffects, obj) then
                                table.insert(blurEffects, obj)
                                obj.Enabled = false
                            end
                        end
                    end
                end
            end
        end)
        
        createnotify("Anti Bee Activated!")
    else
        if antiBeeConnection then
            antiBeeConnection:Disconnect()
            antiBeeConnection = nil
        end
        
        blurEffects = {}
        lastBlurCheck = 0
        createnotify("Anti Bee Deactivated!")
    end
end)

-- Anti Ragdoll
createToggle(ProtectionTab, "الحماية من الوقوع", false, function(state)
    antiRagdollActive = state
    
    local ragdollConnections = {}
    local cachedCharData = {}

    local function cacheCharacterData()
        local char = LocalPlayer.Character
        if not char then return false end
        
        local hum = char:FindFirstChildOfClass("Humanoid")
        local root = char:FindFirstChild("HumanoidRootPart")
        
        if not hum or not root then return false end
        
        cachedCharData = {
            character = char,
            humanoid = hum,
            root = root,
            originalWalkSpeed = hum.WalkSpeed,
            originalJumpPower = hum.JumpPower,
            isFrozen = false
        }
        
        return true
    end

    local function disconnectAll()
        for _, conn in ipairs(ragdollConnections) do
            if typeof(conn) == "RBXScriptConnection" then
                pcall(function() conn:Disconnect() end)
            end
        end
        ragdollConnections = {}
    end

    local function isRagdolled()
        if not cachedCharData.humanoid then return false end
        
        local hum = cachedCharData.humanoid
        local state = hum:GetState()
        
        local ragdollStates = {
            [Enum.HumanoidStateType.Physics] = true,
            [Enum.HumanoidStateType.Ragdoll] = true,
            [Enum.HumanoidStateType.FallingDown] = true
        }
        
        if ragdollStates[state] then
            return true
        end
        
        local endTime = LocalPlayer:GetAttribute("RagdollEndTime")
        if endTime then
            local now = workspace:GetServerTimeNow()
            if (endTime - now) > 0 then
                return true
            end
        end
        
        return false
    end

    local function removeRagdollConstraints()
        if not cachedCharData.character then return end
        
        local removed = false
        
        for _, descendant in ipairs(cachedCharData.character:GetDescendants()) do
            if descendant:IsA("BallSocketConstraint") or 
               (descendant:IsA("Attachment") and descendant.Name:find("RagdollAttachment")) then
                pcall(function()
                    descendant:Destroy()
                    removed = true
                end)
            end
        end
        
        return removed
    end

    local function forceExitRagdoll()
        if not cachedCharData.humanoid or not cachedCharData.root then return end
        
        local hum = cachedCharData.humanoid
        local root = cachedCharData.root
        
        pcall(function()
            local now = workspace:GetServerTimeNow()
            LocalPlayer:SetAttribute("RagdollEndTime", now)
        end)
        
        if hum.Health > 0 then
            hum:ChangeState(Enum.HumanoidStateType.Running)
        end
        
        root.Anchored = false
        root.AssemblyLinearVelocity = Vector3.zero
        root.AssemblyAngularVelocity = Vector3.zero
    end

    local function freezePlayer()
        if not cachedCharData.humanoid or not cachedCharData.root then return end
        if cachedCharData.isFrozen then return end
        
        local hum = cachedCharData.humanoid
        local root = cachedCharData.root
        
        cachedCharData.originalWalkSpeed = hum.WalkSpeed
        cachedCharData.originalJumpPower = hum.JumpPower
        
        hum.WalkSpeed = 0
        hum.JumpPower = 0
        root.Anchored = true
        root.AssemblyLinearVelocity = Vector3.zero
        root.AssemblyAngularVelocity = Vector3.zero
        
        cachedCharData.isFrozen = true
    end

    local function unfreezePlayer()
        if not cachedCharData.humanoid or not cachedCharData.root then return end
        if not cachedCharData.isFrozen then return end
        
        local hum = cachedCharData.humanoid
        local root = cachedCharData.root
        
        hum.WalkSpeed = cachedCharData.originalWalkSpeed or 16
        hum.JumpPower = cachedCharData.originalJumpPower or 50
        
        root.Anchored = false
        root.AssemblyLinearVelocity = Vector3.zero
        root.AssemblyAngularVelocity = Vector3.zero
        
        cachedCharData.isFrozen = false
    end

    local function v1HeartbeatLoop()
        while antiRagdollActive and cachedCharData.humanoid do
            task.wait()
            
            if isRagdolled() then
                removeRagdollConstraints()
                forceExitRagdoll()
            end
        end
    end

    local function v2HeartbeatLoop()
        while antiRagdollActive and cachedCharData.humanoid do
            task.wait()
            
            if isRagdolled() then
                freezePlayer()
            else
                unfreezePlayer()
            end
        end
    end

    local function setupCameraBinding()
        if not cachedCharData.humanoid then return end
        
        local conn = RunService.RenderStepped:Connect(function()
            if not antiRagdollActive then return end
            
            local cam = workspace.CurrentCamera
            if cam and cachedCharData.humanoid and cam.CameraSubject ~= cachedCharData.humanoid then
                cam.CameraSubject = cachedCharData.humanoid
            end
        end)
        
        table.insert(ragdollConnections, conn)
    end

    local function onCharacterAdded(char)
        task.wait(0.5)
        
        if not antiRagdollActive then return end
        
        if cacheCharacterData() then
            setupCameraBinding()
            task.spawn(v1HeartbeatLoop)
        end
    end

    if state then
        if cacheCharacterData() then
            local charConn = LocalPlayer.CharacterAdded:Connect(onCharacterAdded)
            table.insert(ragdollConnections, charConn)
            
            setupCameraBinding()
            task.spawn(v1HeartbeatLoop)
            createnotify("Anti Ragdoll Activated!")
        end
    else
        if cachedCharData.isFrozen then
            unfreezePlayer()
        end
        
        disconnectAll()
        cachedCharData = {}
        createnotify("Anti Ragdoll Deactivated!")
    end
end)

