createToggle(StealTab, "جاذبية قليلة", false, function(state)
    gravityLow = state
    local NORMAL_GRAV = 196.2
    local REDUCED_GRAV = 100
    local NORMAL_JUMP = 50
    local BOOST_JUMP = 80
    
    if state then
        -- Spoof gravity
        local spoofedGravity = REDUCED_GRAV
        pcall(function()
            local mt = getrawmetatable(Workspace)
            if mt then
                setreadonly(mt, false)
                local oldIndex = mt.__index
                mt.__index = function(self, k)
                    if k == 'Gravity' then
                        return spoofedGravity
                    end
                    return oldIndex(self, k)
                end
                setreadonly(mt, true)
            end
        end)
        
        -- Set jump power
        local h = player.Character and player.Character:FindFirstChildOfClass('Humanoid')
        if h then
            h.JumpPower = BOOST_JUMP
            h.UseJumpPower = true
        end
        
        -- Anti ragdoll
        local char = player.Character
        if char then
            for _, v in pairs(char:GetDescendants()) do
                if v:IsA('BodyVelocity') or v:IsA('BodyAngularVelocity') then
                    v:Destroy()
                end
            end
        end
        
        -- Force field
        if char then
            if not char:FindFirstChildOfClass('ForceField') then
                local ff = Instance.new('ForceField', char)
                ff.Visible = false
            end
        end
        
        createnotify("Low Gravity Activated!")
    else
        -- Restore gravity
        local spoofedGravity = NORMAL_GRAV
        pcall(function()
            local mt = getrawmetatable(Workspace)
            if mt then
                setreadonly(mt, false)
                local oldIndex = mt.__index
                mt.__index = function(self, k)
                    if k == 'Gravity' then
                        return spoofedGravity
                    end
                    return oldIndex(self, k)
                end
                setreadonly(mt, true)
            end
        end)
        
        -- Restore jump power
        local h = player.Character and player.Character:FindFirstChildOfClass('Humanoid')
        if h then
            h.JumpPower = NORMAL_JUMP
        end
        
        -- Remove force field
        local char = player.Character
        if char then
            for _, ff in ipairs(char:GetChildren()) do
                if ff:IsA('ForceField') then
                    ff:Destroy()
                end
            end
        end
        
        createnotify("Low Gravity Deactivated!")
    end
end)

