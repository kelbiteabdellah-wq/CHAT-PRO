-- Auto Laser Cape
local laserThread = nil
local equipThread = nil
createToggle(AutoTab, "إطلاق آلي عباءة الليزر", false, function(state)
    laserCapeActive = state
    
    local function forceEquipLaserCape()
        local char = player.Character
        if not char then return nil end
        local backpack = player:FindFirstChild("Backpack")
        local cape = nil
        if backpack then
            for _, tool in pairs(backpack:GetChildren()) do
                if tool:IsA("Tool") and (string.find(tool.Name:lower(), "laser") or string.find(tool.Name:lower(), "cape")) then
                    cape = tool break
                end
            end
        end
        if not cape and char then
            for _, tool in pairs(char:GetChildren()) do
                if tool:IsA("Tool") and (string.find(tool.Name:lower(), "laser") or string.find(tool.Name:lower(), "cape")) then
                    cape = tool break
                end
            end
        end
        if cape and cape.Parent == backpack then
            local hum = char:FindFirstChildOfClass("Humanoid")
            if hum then hum:EquipTool(cape) end
        end
        return cape
    end

    local function maintainEquipped()
        while laserCapeActive do
            local char = player.Character
            if char then
                local equipped = false
                for _, tool in pairs(char:GetChildren()) do
                    if tool:IsA("Tool") and (string.find(tool.Name:lower(), "laser") or string.find(tool.Name:lower(), "cape")) then
                        equipped = true break
                    end
                end
                if not equipped then forceEquipLaserCape() end
            end
            task.wait(0.3)
        end
    end

    local function shootLaser()
        local success = pcall(function()
            local Net = require(ReplicatedStorage:WaitForChild("Packages").Net)
            local char = player.Character
            if not char then return end
            local cape = forceEquipLaserCape()
            if not cape then return end
            
            local closest = nil
            local bestDist = math.huge
            local myPos = char.HumanoidRootPart.Position
            
            for _, p in Players:GetPlayers() do
                if p ~= player and p.Character then
                    local hum = p.Character:FindFirstChildOfClass("Humanoid")
                    local root = p.Character:FindFirstChild("HumanoidRootPart")
                    if hum and hum.Health > 0 and root then
                        local dist = (root.Position - myPos).Magnitude
                        if dist < bestDist then
                            bestDist = dist
                            closest = p
                        end
                    end
                end
            end
            
            if closest then
                local root = closest.Character.HumanoidRootPart
                Net:RemoteEvent("UseItem"):FireServer(root.Position, root)
            end
        end)
        return success
    end

    if state then
        equipThread = task.spawn(maintainEquipped)
        laserThread = task.spawn(function()
            while laserCapeActive do
                shootLaser()
                task.wait(0.4)
            end
        end)
        createnotify("Auto Laser Cape Activated!")
    else
        if laserThread then task.cancel(laserThread) end
        if equipThread then task.cancel(equipThread) end
        createnotify("Auto Laser Cape Deactivated!")
    end
end)

-- Auto Web Slinger
local teleportLoop = nil
local currentTarget = nil
createToggle(AutoTab, "ايمبوت أداة العنكبوت", false, function(state)
    mataPlayerAtivo = state
    
    local function getEnemyPlayer()
        if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then
            return nil
        end
        
        local closest, distance = nil, math.huge
        for _, targetPlayer in pairs(Players:GetPlayers()) do
            if targetPlayer ~= player and targetPlayer.Character and targetPlayer.Character:FindFirstChild("HumanoidRootPart") then
                local part = targetPlayer.Character.HumanoidRootPart
                local mag = (part.Position - player.Character.HumanoidRootPart.Position).Magnitude
                if mag < distance then
                    distance = mag
                    closest = targetPlayer
                end
            end
        end
        return closest
    end

    local function equipWebSlinger()
        local backpack = player:FindFirstChild("Backpack")
        local webSlinger = nil
        
        if backpack then
            webSlinger = backpack:FindFirstChild("Web Slinger")
        end
        
        if not webSlinger and player.Character then
            webSlinger = player.Character:FindFirstChild("Web Slinger")
        end
        
        if webSlinger and webSlinger.Parent == backpack then
            player.Character.Humanoid:EquipTool(webSlinger)
            return true
        elseif webSlinger and webSlinger.Parent == player.Character then
            return true
        end
        
        return false
    end

    local function executeAimbot()
        if not equipWebSlinger() then
            return false, nil
        end
        
        task.wait(0.1)
        
        local enemy = getEnemyPlayer()
        if not enemy then
            return false, nil
        end
        
        local targetPosition = enemy.Character.HumanoidRootPart.Position
        
        local args = {
            [1] = targetPosition,
            [2] = enemy.Character.HumanoidRootPart
        }
        
        local success = pcall(function()
            ReplicatedStorage:WaitForChild("Packages"):WaitForChild("Net"):WaitForChild("RE/UseItem"):FireServer(unpack(args))
        end)
        
        if success then
            return true, enemy
        else
            return false, nil
        end
    end

    local function startTeleportLoop(target)
        if not target or not target.Character then 
            return 
        end
        
        local hrp = target.Character:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        
        if teleportLoop then 
            teleportLoop:Disconnect() 
        end
        
        local above = true
        teleportLoop = RunService.Heartbeat:Connect(function()
            if target and target.Character and hrp and hrp.Parent and target ~= player then
                if above then
                    hrp.CFrame = CFrame.new(hrp.Position + Vector3.new(0, 20, 0))
                else
                    hrp.CFrame = CFrame.new(hrp.Position + Vector3.new(0, -20, 0))
                end
                above = not above
            else
                if teleportLoop then
                    teleportLoop:Disconnect()
                    teleportLoop = nil
                end
            end
            task.wait(0.5)
        end)
    end

    local function stopTeleportLoop()
        if teleportLoop then
            teleportLoop:Disconnect()
            teleportLoop = nil
            currentTarget = nil
        end
    end

    if state then
        task.spawn(function()
            while mataPlayerAtivo do
                local enemy = getEnemyPlayer()
                
                if enemy then
                    local aimbotSuccess, target = executeAimbot()
                    
                    if aimbotSuccess then
                        task.wait(0.5)
                        startTeleportLoop(target)
                    end
                end
                task.wait(1)
            end
        end)
        createnotify("Auto Web Slinger Activated!")
    else
        stopTeleportLoop()
        createnotify("Auto Web Slinger Deactivated!")
    end
end)

