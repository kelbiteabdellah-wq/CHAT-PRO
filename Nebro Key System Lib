local notifIndex = 0
local function notify(text, kind)
	kind = tostring(kind or "info")
	local c = T.Accent
	if kind == "success" then
		c = T.Success
	elseif kind == "error" then
		c = T.Error
	elseif kind == "warning" then
		c = T.Warning
	end

	notifIndex -= 1

	local card = create("Frame", {
		Size = UDim2.new(0, 300, 0, 44),
		BackgroundColor3 = T.Panel2,
		BorderSizePixel = 0,
		LayoutOrder = notifIndex,
		Parent = notifHolder
	})
	roundify(card, UDim.new(0, 10))
	stroke(card, 1.2, c, 0.1)

	local accent = create("Frame", {
		Size = UDim2.new(0, 4, 1, -14),
		Position = UDim2.new(0, 10, 0, 7),
		BackgroundColor3 = c,
		BorderSizePixel = 0,
		Parent = card
	})
	roundify(accent, UDim.new(1, 0))

	local lbl = create("TextLabel", {
		BackgroundTransparency = 1,
		Position = UDim2.new(0, 22, 0, 0),
		Size = UDim2.new(1, -30, 1, 0),
		Text = tostring(text),
		TextColor3 = T.Text,
		Font = Enum.Font.GothamBold,
		TextSize = 14,
		TextXAlignment = Enum.TextXAlignment.Left,
		TextWrapped = true,
		Parent = card
	})

	card.BackgroundTransparency = 1
	lbl.TextTransparency = 1
	accent.BackgroundTransparency = 1

	tween(card, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundTransparency = 0})
	tween(lbl, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {TextTransparency = 0})
	tween(accent, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundTransparency = 0})

	task.delay(2.05, function()
		if card and card.Parent then
			tween(card, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundTransparency = 1})
			tween(lbl, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {TextTransparency = 1})
			tween(accent, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundTransparency = 1})
			task.wait(0.2)
			if card then
				card:Destroy()
			end
		end
	end)
end

