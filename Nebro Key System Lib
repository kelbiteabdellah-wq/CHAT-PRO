function NEBROLIB.Init(config)
	config = config or {}
	merge(NEBROLIB.Settings, config)
	merge(T, NEBROLIB.Settings.Theme)

	title.Text = NEBROLIB.Settings.Title
	title2.Text = NEBROLIB.Settings.SubTitle
	subtitle.Text = NEBROLIB.Settings.Author
	keyTitle.Text = NEBROLIB.Settings.KeyName
	mainFrame.Size = UDim2.new(0, NEBROLIB.Settings.Width, 0, NEBROLIB.Settings.Height)

	task.spawn(function()
		local introFrame = create("Frame", {
			AnchorPoint = Vector2.new(0.5, 0.5),
			Position = UDim2.new(0.5, 0, 0.5, 0),
			Size = UDim2.new(0, 0, 0, 0),
			BackgroundColor3 = T.Panel,
			BorderSizePixel = 0,
			Parent = screenGui
		})
		round(introFrame, UDim.new(0, 10))
		stroke(introFrame, 2, T.Accent, 0.08)

		local introLabel = create("TextLabel", {
			BackgroundTransparency = 1,
			AnchorPoint = Vector2.new(0.5, 0.5),
			Position = UDim2.new(0.5, 0, 0.5, 0),
			Size = UDim2.new(1, -18, 1, -18),
			Text = NEBROLIB.Settings.IntroText or "NEBROLIB",
			TextColor3 = T.Accent,
			TextStrokeTransparency = 0.6,
			TextStrokeColor3 = Color3.fromRGB(0, 0, 0),
			Font = Enum.Font.GothamBlack,
			TextScaled = true,
			Parent = introFrame
		})

		introFrame.Visible = true
		introFrame.Size = UDim2.new(0, 0, 0, 62)
		tween(introFrame, TweenInfo.new(0.25, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
			Size = UDim2.new(0, 300, 0, 62)
		})
		task.wait(0.33)
		task.wait(1.3)
		tween(introFrame, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
			Size = UDim2.new(0, 0, 0, 62),
			Position = UDim2.new(0.5, 0, 0.5, -10)
		})
		task.wait(0.2)
		introFrame:Destroy()

		if NEBROLIB.Settings.KeySystem then
			openKeyModal()
		else
			revealToggle()
		end
	end)
end

keyClose.MouseButton1Click:Connect(function()
	keyModal.Visible = false
	overlay.Visible = false
end)

confirmBtn.MouseButton1Click:Connect(function()
	if validateKey(keyBox.Text) then
		notify("Key accepted", "success")
		closeKeyModal()
		revealToggle()
	else
		notify("Invalid key", "error")
		tween(keyBox, TweenInfo.new(0.08, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			BackgroundColor3 = Color3.fromRGB(60, 25, 25)
		})
		task.delay(0.15, function()
			if keyBox and keyBox.Parent then
				tween(keyBox, TweenInfo.new(0.08, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
					BackgroundColor3 = T.BG
				})
			end
		end)
	end
end)

closeBtn.MouseButton1Click:Connect(function()
	hideMain()
end)

minBtn.MouseButton1Click:Connect(function()
	if not mainFrame.Visible then return end
	if pagesContainer.Visible then
		pagesContainer.Visible = false
		tabContainer.Visible = false
		minBtn.Text = "+"
		tween(mainFrame, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			Size = UDim2.new(0, NEBROLIB.Settings.Width, 0, 40)
		})
	else
		pagesContainer.Visible = true
		tabContainer.Visible = true
		minBtn.Text = "-"
		tween(mainFrame, TweenInfo.new(0.2, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
			Size = UDim2.new(0, NEBROLIB.Settings.Width, 0, NEBROLIB.Settings.Height)
		})
	end
end)

toggleBtn.MouseButton1Click:Connect(function()
	if mainFrame.Visible then
