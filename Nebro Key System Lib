local function mergeTable(a, b)
	if type(b) ~= "table" then return a end
	for k, v in pairs(b) do
		if type(v) == "table" and type(a[k]) == "table" then
			mergeTable(a[k], v)
		else
			a[k] = v
		end
	end
	return a
end

local function create(className, props)
	local inst = Instance.new(className)
	for k, v in pairs(props or {}) do
		inst[k] = v
	end
	return inst
end

local function roundify(parent, radius)
	local c = Instance.new("UICorner")
	c.CornerRadius = radius or UDim.new(0, 8)
	c.Parent = parent
	return c
end

local function border(parent, thickness, color, transparency)
	local s = Instance.new("UIStroke")
	s.Thickness = thickness or 1.2
	s.Color = color or T.Accent
	s.Transparency = transparency or 0.15
	s.Parent = parent
	return s
end

local function pad(parent, l, t, r, b)
	local p = Instance.new("UIPadding")
	p.PaddingLeft = UDim.new(0, l or 0)
	p.PaddingTop = UDim.new(0, t or 0)
	p.PaddingRight = UDim.new(0, r or 0)
	p.PaddingBottom = UDim.new(0, b or 0)
	p.Parent = parent
	return p
end

local function tween(obj, timeOrInfo, props)
	local info = typeof(timeOrInfo) == "TweenInfo" and timeOrInfo or TweenInfo.new(timeOrInfo or 0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
	local tw = TweenService:Create(obj, info, props)
	tw:Play()
	return tw
end

local function trimLower(s)
	s = tostring(s or "")
	s = s:gsub("^%s+", ""):gsub("%s+$", "")
	return string.lower(s)
end

local function attachScale(obj)
	local scale = obj:FindFirstChildOfClass("UIScale")
	if not scale then
		scale = Instance.new("UIScale")
		scale.Scale = 1
		scale.Parent = obj
	end
	return scale
end

local function setInteractiveMotion(obj, opts)
	opts = opts or {}
	local scale = attachScale(obj)
	local normalBg = obj.BackgroundColor3
	local hoverBg = opts.hoverBg or normalBg
	local downScale = opts.downScale or 0.98
	local hoverScale = opts.hoverScale or 1.02
	local normalStrokeTransparency = nil
	local s = obj:FindFirstChildOfClass("UIStroke")
	if s then
		normalStrokeTransparency = s.Transparency
	end

	obj.MouseEnter:Connect(function()
		if hoverBg then
			tween(obj, 0.12, {BackgroundColor3 = hoverBg})
		end
		tween(scale, 0.12, {Scale = hoverScale})
		if s and opts.hoverStrokeTransparency ~= nil then
			tween(s, 0.12, {Transparency = opts.hoverStrokeTransparency})
		end
	end)

	obj.MouseLeave:Connect(function()
		tween(obj, 0.12, {BackgroundColor3 = normalBg})
		tween(scale, 0.12, {Scale = 1})
		if s and normalStrokeTransparency ~= nil then
			tween(s, 0.12, {Transparency = normalStrokeTransparency})
		end
	end)

	obj.MouseButton1Down:Connect(function()
		tween(scale, 0.06, {Scale = downScale})
	end)

	obj.MouseButton1Up:Connect(function()
		tween(scale, 0.08, {Scale = hoverScale})
	end)
end

local function makeDraggable(frame, handle)
	handle = handle or frame
	local dragging = false
	local dragInput, mousePos, framePos

	handle.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			mousePos = input.Position
			framePos = frame.Position
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging = false
				end
			end)
		end
	end)

	handle.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
			dragInput = input
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if dragging and input == dragInput then
			local delta = input.Position - mousePos
			frame.Position = UDim2.new(
				framePos.X.Scale, framePos.X.Offset + delta.X,
				framePos.Y.Scale, framePos.Y.Offset + delta.Y
			)
		end
	end)
end

