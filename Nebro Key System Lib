		Text = tostring(text),
		TextColor3 = T.Text,
		Font = Enum.Font.Gotham,
		TextSize = 13.5,
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = box
	})

	local toggle = create("TextButton", {
		Size = UDim2.new(0, 48, 0, 22),
		Position = UDim2.new(1, -50, 0.5, -11),
		BackgroundColor3 = default and T.Accent or T.Panel2,
		Text = "",
		AutoButtonColor = false,
		BorderSizePixel = 0,
		Parent = box
	})
	roundify(toggle, UDim.new(1, 0))
	stroke(toggle, 1.1, T.Accent, 0.15)

	local knob = create("Frame", {
		Size = UDim2.new(0, 18, 0, 18),
		Position = default and UDim2.new(1, -20, 0.5, -9) or UDim2.new(0, 2, 0.5, -9),
		BackgroundColor3 = Color3.fromRGB(255, 255, 255),
		BorderSizePixel = 0,
		Parent = toggle
	})
	roundify(knob, UDim.new(1, 0))

	local state = default and true or false
	local function update(animated)
		if state then
			toggle.BackgroundColor3 = T.Accent
			if animated then
				knob:TweenPosition(UDim2.new(1, -20, 0.5, -9), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.12, true)
			else
				knob.Position = UDim2.new(1, -20, 0.5, -9)
			end
		else
			toggle.BackgroundColor3 = T.Panel2
			if animated then
				knob:TweenPosition(UDim2.new(0, 2, 0.5, -9), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.12, true)
			else
				knob.Position = UDim2.new(0, 2, 0.5, -9)
			end
		end
	end

	toggle.MouseButton1Click:Connect(function()
		state = not state
		update(true)
		if callback then
			callback(state)
		end
	end)

	update(false)
	return box
end

function NEBROLIB.createSlider(parent, labelText, min, max, defaultValue, callback)
	min = tonumber(min) or 0
	max = tonumber(max) or 100
	defaultValue = tonumber(defaultValue) or min

	local box = boxBase(parent, 54)

	local row = create("Frame", {
		BackgroundTransparency = 1,
		Size = UDim2.new(1, 0, 0, 18),
		Parent = box
	})

	create("TextLabel", {
		BackgroundTransparency = 1,
		Size = UDim2.new(1, -48, 1, 0),
		Text = tostring(labelText or "Slider"),
		TextColor3 = T.Text,
		Font = Enum.Font.Gotham,
		TextSize = 13.5,
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = row
	})

	local valueLabel = create("TextLabel", {
		BackgroundTransparency = 1,
		Position = UDim2.new(1, -48, 0, 0),
		Size = UDim2.new(0, 48, 1, 0),
		Text = tostring(defaultValue),
		TextColor3 = T.Accent,
		Font = Enum.Font.GothamBold,
		TextSize = 13.5,
		TextXAlignment = Enum.TextXAlignment.Right,
		Parent = row
	})

	local bar = create("Frame", {
		Position = UDim2.new(0, 0, 0, 28),
		Size = UDim2.new(1, 0, 0, 10),
		BackgroundColor3 = T.Panel2,
		BorderSizePixel = 0,
		Parent = box
	})
	roundify(bar, UDim.new(1, 0))
	stroke(bar, 1, T.Accent, 0.25)

	local fill = create("Frame", {
		BackgroundColor3 = T.Accent,
		BorderSizePixel = 0,
		Parent = bar
	})
	roundify(fill, UDim.new(1, 0))

	local knob = create("Frame", {
		Size = UDim2.new(0, 16, 0, 16),
		BackgroundColor3 = T.Accent,
		BorderSizePixel = 0,
		Parent = bar
	})
	roundify(knob, UDim.new(1, 0))
	stroke(knob, 1, Color3.fromRGB(255, 255, 255), 0.55)

	local dragging = false

	local function setValue(v, fire)
		v = math.clamp(math.floor(v + 0.5), min, max)
		local percent = (v - min) / math.max(1, (max - min))
		fill.Size = UDim2.new(percent, 0, 1, 0)
		knob.Position = UDim2.new(percent, -8, 0.5, -8)
		valueLabel.Text = tostring(v)
		if fire and callback then
			callback(v)
		end
	end

	local function getValueFromX(x)
		local rel = x - bar.AbsolutePosition.X
		local percent = math.clamp(rel / math.max(1, bar.AbsoluteSize.X), 0, 1)
		return min + ((max - min) * percent)
	end

	bar.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			setValue(getValueFromX(input.Position.X), true)
		end
	end)

	knob.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			setValue(getValueFromX(input.Position.X), true)
		end
	end)

	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end)

	setValue(defaultValue, false)
	return box
end

function NEBROLIB.makeWindow(titleStr, subtitleStr, authorStr)
	NEBROLIB.Settings.Title = titleStr or NEBROLIB.Settings.Title
	NEBROLIB.Settings.SubTitle = subtitleStr or NEBROLIB.Settings.SubTitle
	NEBROLIB.Settings.Author = authorStr or NEBROLIB.Settings.Author
	title.Text = NEBROLIB.Settings.Title
	title2.Text = NEBROLIB.Settings.SubTitle
	subtitle.Text = NEBROLIB.Settings.Author
end

local function intro(text)
	local introFrame = create("Frame", {
		AnchorPoint = Vector2.new(0.5, 0.5),
		Position = UDim2.new(0.5, 0, 0.5, 0),
		Size = UDim2.new(0, 0, 0, 0),
		BackgroundColor3 = T.Panel,
		BorderSizePixel = 0,
		Parent = screenGui
	})
	roundify(introFrame, UDim.new(0, 10))
	stroke(introFrame, 2, T.Accent, 0.08)

	local introText = create("TextLabel", {
		BackgroundTransparency = 1,
		AnchorPoint = Vector2.new(0.5, 0.5),
		Position = UDim2.new(0.5, 0, 0.5, 0),
		Size = UDim2.new(1, -18, 1, -18),
		Text = text or "NEBROLIB",
		TextColor3 = T.Accent,
		TextStrokeTransparency = 0.6,
		TextStrokeColor3 = Color3.fromRGB(0, 0, 0),
		Font = Enum.Font.GothamBlack,
		TextScaled = true,
		Parent = introFrame
	})

	local w, h = 300, 62
	introFrame.Visible = true
	introFrame.Size = UDim2.new(0, 0, 0, h)
	tween(introFrame, 0.28, {Size = UDim2.new(0, w, 0, h)}, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
	task.wait(0.35)
	task.wait(1.5)
	tween(introFrame, 0.22, {
		Size = UDim2.new(0, 0, 0, h),
		Position = UDim2.new(0.5, 0, 0.5, -10)
	}, Enum.EasingStyle.Quad, Enum.EasingDirection.In)
	task.wait(0.24)
	introFrame:Destroy()
end

function NEBROLIB.makeIntro(introText)
	NEBROLIB.Settings.IntroText = introText or NEBROLIB.Settings.IntroText
	intro(NEBROLIB.Settings.IntroText)
end

local function selectFirstTabIfNeeded()
	if selectedTab then return end
	if #tabs > 0 then
		selectTab(tabs[1])
	end
end

local function openMain()
	createToggleButton()
	tabContainer.Visible = true
	pagesContainer.Visible = true
	minimized = false
	minBtn.Text = "-"
	setMainVisible(true)
	selectFirstTabIfNeeded()
end

local function hideMain()
	setMainVisible(false)
end

local function openKeyModal()
	overlay.Visible = true
	overlay.BackgroundTransparency = 1
	tween(overlay, 0.18, {BackgroundTransparency = 0.35}, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

	keyModal.Visible = true
	keyModal.BackgroundTransparency = 0
	keyModal.Size = UDim2.new(0, 320, 0, 172)
	tween(keyModal, 0.24, {Size = UDim2.new(0, 360, 0, 190)}, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
end

local function closeKeyModal()
	tween(keyModal, 0.18, {
		Size = UDim2.new(0, 320, 0, 172),
		BackgroundTransparency = 1
	}, Enum.EasingStyle.Quad, Enum.EasingDirection.In)
	tween(overlay, 0.18, {BackgroundTransparency = 1}, Enum.EasingStyle.Quad, Enum.EasingDirection.In)
	task.wait(0.18)
	keyModal.Visible = false
	overlay.Visible = false
	keyModal.BackgroundTransparency = 0
	overlay.BackgroundTransparency = 1
end

local function validateKey(entered)
	local key = trimLower(entered)
	for _, valid in ipairs(NEBROLIB.Settings.ValidKeys or {}) do
		if key == trimLower(valid) then
			return true
		end
	end
	return false
end

local function unlockLibrary()
	closeKeyModal()
	createToggleButton()
	openMain()
	notify("Key accepted", "success")
end

keyClose.MouseButton1Click:Connect(function()
	closeKeyModal()
end)

confirmBtn.MouseButton1Click:Connect(function()
	local entered = keyBox.Text or ""
	if validateKey(entered) then
		unlockLibrary()
	else
		notify("Invalid key", "error")
		tween(keyBox, 0.08, {BackgroundColor3 = Color3.fromRGB(60, 25, 25)}, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
		shake(keyModal)
		task.delay(0.16, function()
			if keyBox and keyBox.Parent then
				tween(keyBox, 0.08, {BackgroundColor3 = T.BG}, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
			end
		end)
	end
end)

closeBtn.MouseButton1Click:Connect(function()
	hideMain()
end)

minBtn.MouseButton1Click:Connect(function()
	if not mainFrame.Visible then return end
	minimized = not minimized
	if minimized then
		tabContainer.Visible = false
		pagesContainer.Visible = false
		minBtn.Text = "+"
		tween(mainFrame, 0.2, {Size = UDim2.new(0, NEBROLIB.Settings.Width, 0, 40)}, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
	else
		tabContainer.Visible = true
		pagesContainer.Visible = true
		minBtn.Text = "-"
		tween(mainFrame, 0.22, {Size = UDim2.new(0, NEBROLIB.Settings.Width, 0, NEBROLIB.Settings.Height)}, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
	end
end)

makeDraggable(mainFrame, topBar)

function NEBROLIB.Init(config)
	config = config or {}
	mergeTable(NEBROLIB.Settings, config)
	mergeTable(T, NEBROLIB.Settings.Theme)

	title.Text = NEBROLIB.Settings.Title
	title2.Text = NEBROLIB.Settings.SubTitle
	subtitle.Text = NEBROLIB.Settings.Author
	keyTitle.Text = NEBROLIB.Settings.KeyName
	mainFrame.Size = UDim2.new(0, NEBROLIB.Settings.Width, 0, NEBROLIB.Settings.Height)

	task.spawn(function()
		intro(NEBROLIB.Settings.IntroText)
		if NEBROLIB.Settings.KeySystem then
			openKeyModal()
		else
			createToggleButton()
			openMain()
		end
	end)
end

NEBROLIB.notify = notify
NEBROLIB.show = openMain
NEBROLIB.hide = hideMain
NEBROLIB.screenGui = screenGui
NEBROLIB.mainFrame = mainFrame
NEBROLIB.keyModal = keyModal
NEBROLIB.overlay = overlay

return NEBROLIB
