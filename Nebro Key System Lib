function NEBROLIB.createDropdown(parent, options, defaultIndex, callback)
	options = options or {}
	local box = baseBox(parent, 50)

	local mainBtn = create("TextButton", {
		Size = UDim2.new(1, 0, 0, 26),
		BackgroundColor3 = T.BG,
		Text = tostring(options[defaultIndex or 1] or options[1] or "None"),
		TextColor3 = T.Text,
		Font = Enum.Font.Gotham,
		TextSize = 13,
		BorderSizePixel = 0,
		Parent = box
	})
	round(mainBtn, UDim.new(0, 7))
	stroke(mainBtn, 1.1, T.Accent, 0.2)

	local listFrame = create("Frame", {
		Visible = false,
		Position = UDim2.new(0, 0, 1, 4),
		Size = UDim2.new(1, 0, 0, 0),
		BackgroundColor3 = T.BG,
		BorderSizePixel = 0,
		Parent = box
	})
	round(listFrame, UDim.new(0, 7))
	stroke(listFrame, 1.1, T.Accent, 0.2)

	local scroll = create("ScrollingFrame", {
		BackgroundTransparency = 1,
		Size = UDim2.new(1, 0, 1, 0),
		ScrollBarThickness = 4,
		AutomaticCanvasSize = Enum.AutomaticSize.Y,
		CanvasSize = UDim2.new(0, 0, 0, 0),
		Parent = listFrame
	})
	padding(scroll, 6, 6, 6, 6)
	create("UIListLayout", {
		Padding = UDim.new(0, 4),
		SortOrder = Enum.SortOrder.LayoutOrder,
		Parent = scroll
	})

	local open = false

	for _, opt in ipairs(options) do
		local item = create("TextButton", {
			Size = UDim2.new(1, 0, 0, 24),
			BackgroundColor3 = T.Panel2,
			Text = tostring(opt),
			TextColor3 = T.Text,
			Font = Enum.Font.Gotham,
			TextSize = 12,
			BorderSizePixel = 0,
			Parent = scroll
		})
		round(item, UDim.new(0, 6))
		stroke(item, 1, T.Accent, 0.45)

		item.MouseButton1Click:Connect(function()
			mainBtn.Text = tostring(opt)
			open = false
			listFrame.Visible = false
			if callback then callback(opt) end
		end)
	end

	local h = math.clamp(#options * 28 + 10, 32, 144)
	listFrame.Size = UDim2.new(1, 0, 0, h)

	mainBtn.MouseButton1Click:Connect(function()
		open = not open
		listFrame.Visible = open
	end)

	return box
end

function NEBROLIB.createToggle(parent, text, default, callback)
	local box = baseBox(parent, 44)

	create("TextLabel", {
		BackgroundTransparency = 1,
		Size = UDim2.new(1, -54, 1, 0),
		Text = tostring(text),
		TextColor3 = T.Text,
		Font = Enum.Font.Gotham,
		TextSize = 13,
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = box
	})

	local toggle = create("TextButton", {
		Size = UDim2.new(0, 44, 0, 20),
		Position = UDim2.new(1, -46, 0.5, -10),
		BackgroundColor3 = default and T.Accent or T.Panel2,
		Text = "",
		AutoButtonColor = false,
		BorderSizePixel = 0,
		Parent = box
	})
	round(toggle, UDim.new(1, 0))
	stroke(toggle, 1.1, T.Accent, 0.15)

	local knob = create("Frame", {
		Size = UDim2.new(0, 16, 0, 16),
		Position = default and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 2, 0.5, -8),
		BackgroundColor3 = Color3.fromRGB(255, 255, 255),
		BorderSizePixel = 0,
		Parent = toggle
	})
	round(knob, UDim.new(1, 0))

	local state = default and true or false
	local function update(animated)
		if state then
			toggle.BackgroundColor3 = T.Accent
			if animated then
				knob:TweenPosition(UDim2.new(1, -18, 0.5, -8), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.12, true)
			else
				knob.Position = UDim2.new(1, -18, 0.5, -8)
			end
		else
			toggle.BackgroundColor3 = T.Panel2
			if animated then
				knob:TweenPosition(UDim2.new(0, 2, 0.5, -8), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.12, true)
			else
				knob.Position = UDim2.new(0, 2, 0.5, -8)
			end
		end
	end

	toggle.MouseButton1Click:Connect(function()
		state = not state
		update(true)
		if callback then callback(state) end
	end)

	update(false)
	return box
end

function NEBROLIB.createSlider(parent, labelText, min, max, defaultValue, callback)
	min = tonumber(min) or 0
	max = tonumber(max) or 100
	defaultValue = tonumber(defaultValue) or min

	local box = baseBox(parent, 52)

	local row = create("Frame", {
		BackgroundTransparency = 1,
		Size = UDim2.new(1, 0, 0, 16),
		Parent = box
	})

	create("TextLabel", {
		BackgroundTransparency = 1,
		Size = UDim2.new(1, -48, 1, 0),
		Text = tostring(labelText or "Slider"),
		TextColor3 = T.Text,
		Font = Enum.Font.Gotham,
		TextSize = 13,
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = row
	})

	local valueLabel = create("TextLabel", {
		BackgroundTransparency = 1,
		Position = UDim2.new(1, -48, 0, 0),
		Size = UDim2.new(0, 48, 1, 0),
		Text = tostring(defaultValue),
		TextColor3 = T.Accent,
		Font = Enum.Font.GothamBold,
		TextSize = 13,
		TextXAlignment = Enum.TextXAlignment.Right,
		Parent = row
	})

	local bar = create("Frame", {
		Position = UDim2.new(0, 0, 0, 26),
		Size = UDim2.new(1, 0, 0, 10),
		BackgroundColor3 = T.Panel2,
		BorderSizePixel = 0,
		Parent = box
	})
	round(bar, UDim.new(1, 0))
	stroke(bar, 1, T.Accent, 0.25)

	local fill = create("Frame", {
		BackgroundColor3 = T.Accent,
		BorderSizePixel = 0,
		Parent = bar
	})
	round(fill, UDim.new(1, 0))

	local knob = create("Frame", {
		Size = UDim2.new(0, 16, 0, 16),
		BackgroundColor3 = T.Accent,
		BorderSizePixel = 0,
		Parent = bar
	})
	round(knob, UDim.new(1, 0))
	stroke(knob, 1, Color3.fromRGB(255, 255, 255), 0.55)

	local dragging = false

	local function setValue(v, fire)
		v = math.clamp(math.floor(v + 0.5), min, max)
		local p = (v - min) / math.max(1, max - min)
		fill.Size = UDim2.new(p, 0, 1, 0)
		knob.Position = UDim2.new(p, -8, 0.5, -8)
		valueLabel.Text = tostring(v)
		if fire and callback then
			callback(v)
		end
	end

	local function getValueFromX(x)
		local rel = x - bar.AbsolutePosition.X
		local p = math.clamp(rel / math.max(1, bar.AbsoluteSize.X), 0, 1)
		return min + ((max - min) * p)
	end

	bar.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			setValue(getValueFromX(input.Position.X), true)
		end
	end)

	knob.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			setValue(getValueFromX(input.Position.X), true)
		end
	end)

	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end)

	setValue(defaultValue, false)
	return box
end

