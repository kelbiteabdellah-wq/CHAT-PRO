function NEBROLIB.createTab(name, iconText)
	local tabBtn = create("TextButton", {
		Size = UDim2.new(1, 0, 0, 28),
		BackgroundColor3 = T.Panel2,
		BorderSizePixel = 0,
		Text = "",
		Parent = tabContainer
