local function setMainVisible(visible)
	if visible then
		mainFrame.Visible = true
		mainFrame.Size = UDim2.new(0, 0, 0, 0)
		tween(mainFrame, 0.24, {
			Size = UDim2.new(0, NEBROLIB.Settings.Width, 0, NEBROLIB.Settings.Height)
		}, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
	else
		local tw = tween(mainFrame, 0.2, {
			Size = UDim2.new(0, 0, 0, 0)
		}, Enum.EasingStyle.Back, Enum.EasingDirection.In)
		tw.Completed:Wait()
		mainFrame.Visible = false
	end
end

local function createToggleButton()
	if toggleCreated then
		if toggleBtn then
			toggleBtn.Visible = true
		end
		return
	end

	toggleCreated = true
	toggleBtn = create("TextButton", {
		Name = "ToggleButton",
