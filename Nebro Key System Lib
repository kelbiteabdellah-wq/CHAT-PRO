	overlay.Visible = true
	overlay.BackgroundTransparency = 1
	tween(overlay, TweenInfo.new(0.16, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundTransparency = 0.35})

	keyModal.Visible = true
	keyModal.BackgroundTransparency = 0
	keyModal.Size = UDim2.new(0, 320, 0, 172)
	keyScale.Scale = 0.95
	tween(keyScale, TweenInfo.new(0.22, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {Scale = 1})
	tween(keyModal, TweenInfo.new(0.22, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
		Size = UDim2.new(0, 360, 0, 190)
	})
end

local function closeKeyModal()
	tween(overlay, TweenInfo.new(0.14, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {BackgroundTransparency = 1})
	tween(keyScale, TweenInfo.new(0.14, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Scale = 0.95})
	tween(keyModal, TweenInfo.new(0.14, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
		Size = UDim2.new(0, 320, 0, 172)
	})
	task.wait(0.15)
	keyModal.Visible = false
	overlay.Visible = false
	overlay.BackgroundTransparency = 0.35
end

local function validateKey(inputKey)
	local key = trimLower(inputKey)
	for _, v in ipairs(NEBROLIB.Settings.ValidKeys or {}) do
		if key == trimLower(v) then
			return true
		end
	end
	return false
end

local function revealToggle()
