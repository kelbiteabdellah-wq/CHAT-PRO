local function showKeyModal()
	overlay.Visible = true
	overlay.BackgroundTransparency = 1
	tween(overlay, 0.18, {BackgroundTransparency = 0.35})

	keyModal.Visible = true
	keyModal.BackgroundTransparency = 0
	keyModal.Size = UDim2.new(0, 320, 0, 172)
	tween(keyModal, 0.24, {Size = UDim2.new(0, 360, 0, 190)})
end

local function closeKeyModal()
	tween(keyModal, 0.18, {BackgroundTransparency = 1, Size = UDim2.new(0, 320, 0, 172)})
	tween(overlay, 0.18, {BackgroundTransparency = 1})
	task.wait(0.18)
	keyModal.Visible = false
	overlay.Visible = false
	keyModal.BackgroundTransparency = 0
	overlay.BackgroundTransparency = 0.35
end

local function validateKey(k)
	local key = trimLower(k)
	for _, v in ipairs(NEBROLIB.Settings.ValidKeys or {}) do
		if key == trimLower(v) then
			return true
		end
	end
	return false
end

local function unlockLibrary()
	closeKeyModal()
	revealToggleButton()
	showMain()
	notify("Key accepted", "success")
end

keyClose.MouseButton1Click:Connect(function()
	closeKeyModal()
end)

confirmBtn.MouseButton1Click:Connect(function()
	local entered = keyBox.Text or ""
	if validateKey(entered) then
		unlocked = true
		unlockLibrary()
	else
		notify("Invalid key", "error")
		tween(keyBox, 0.08, {BackgroundColor3 = Color3.fromRGB(60, 25, 25)})
		task.delay(0.16, function()
			if keyBox and keyBox.Parent then
				tween(keyBox, 0.08, {BackgroundColor3 = T.BG})
			end
		end)
	end
end)

closeBtn.MouseButton1Click:Connect(function()
	hideMain()
end)

minBtn.MouseButton1Click:Connect(function()
	if not mainFrame.Visible then return end
	if not minimized then
		minimized = true
		pagesContainer.Visible = false
		tabContainer.Visible = false
		minBtn.Text = "+"
		tween(mainFrame, 0.2, {Size = UDim2.new(0, NEBROLIB.Settings.Width, 0, 40)})
	else
		minimized = false
		pagesContainer.Visible = true
		tabContainer.Visible = true
		minBtn.Text = "-"
		tween(mainFrame, 0.22, {Size = expandedSize})
	end
end)

toggleBtn.MouseButton1Click:Connect(function()
	if mainFrame.Visible then
		hideMain()
	else
		pagesContainer.Visible = true
		tabContainer.Visible = true
		minBtn.Text = "-"
		showMain()
	end
end)

makeDraggable(mainFrame, topBar)
makeDraggable(toggleBtn, toggleBtn)
makeDraggable(keyModal, keyHeader)

function NEBROLIB.Init(config)
	config = config or {}
	mergeTable(NEBROLIB.Settings, config)
	mergeTable(T, NEBROLIB.Settings.Theme)
	title.Text = NEBROLIB.Settings.Title
	title2.Text = NEBROLIB.Settings.SubTitle
	subtitle.Text = NEBROLIB.Settings.Author
	keyTitle.Text = NEBROLIB.Settings.KeyName
	mainFrame.Size = UDim2.new(0, NEBROLIB.Settings.Width, 0, NEBROLIB.Settings.Height)
	expandedSize = UDim2.new(0, NEBROLIB.Settings.Width, 0, NEBROLIB.Settings.Height)

	task.spawn(function()
		intro(NEBROLIB.Settings.IntroText)

		if NEBROLIB.Settings.KeySystem then
			toggleBtn.Visible = false
			showKeyModal()
		else
			revealToggleButton()
			showMain()
		end
	end)
end

