local function setSelected(entry)
	for _, t in ipairs(tabs) do
		t.page.Visible = false
		t.button.BackgroundColor3 = T.Panel2
		t.stroke.Transparency = 1
	end
	entry.page.Visible = true
	entry.button.BackgroundColor3 = T.Panel
	entry.stroke.Transparency = 0
	selectedTab = entry
end

