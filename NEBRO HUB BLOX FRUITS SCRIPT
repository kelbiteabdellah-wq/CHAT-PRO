end

-- Toggle
NEBROLIB.createToggle(fruitTab, "Teleport To Fruits", false, function(state)
    FruitTP = state

    if state then
        NEBROLIB.notify("Fruit Teleport Enabled", "success")

        -- Loop
        task.spawn(function()
            while FruitTP do
                pcall(function()
                    FindAndTP()
                end)
                task.wait(0.2) -- تم تهدئته لتقليل اللاغ
            end
        end)

    else
        NEBROLIB.notify("Fruit Teleport Disabled", "error")
    end
end)

-- عند ظهور فاكهة جديدة
workspace.ChildAdded:Connect(function(child)
    if not FruitTP then return end

    if string.find(string.lower(child.Name), "fruit") then
        task.wait(0.1)
        pcall(function()
            TeleportToFruitHandle(child)
        end)
    end
end)

-- عند الموت / إعادة الظهور
Player.CharacterAdded:Connect(function(char)
    if not FruitTP then return end

    task.wait(1)

    task.spawn(function()
        while FruitTP do
            pcall(function()
                FindAndTP()
            end)
            task.wait(0.5)
        end
    end)
end)
