-- Tween
local function tweenToPosition(targetPosition, callback)
    if not AutoChestEnabled then return end

    if CurrentTween then
        CurrentTween:Cancel()
    end

    local distance = (targetPosition - HumanoidRootPart.Position).Magnitude
    if distance < 1111 then
        HumanoidRootPart.CFrame = CFrame.new(targetPosition)
        if callback then callback() end
        return
    end

    local noclip = enableNoclip()

    local tween = TweenService:Create(
        HumanoidRootPart,
        TweenInfo.new(distance / Speed, Enum.EasingStyle.Linear),
        {CFrame = CFrame.new(targetPosition)}
    )

    tween:Play()

    CurrentTween = tween

    tween.Completed:Connect(function()
        if noclip then noclip:Disconnect() end
        if callback then callback() end
    end)
end

-- Get Chest
local function getClosestChest()
    local ChestModels = workspace:FindFirstChild("ChestModels")
    if not ChestModels then return end

    local closest, dist = nil, math.huge

    for _, chest in pairs(ChestModels:GetChildren()) do
        if chest:IsA("Model") and chest.PrimaryPart and not ChestBlacklist[chest] then
            local d = (HumanoidRootPart.Position - chest.PrimaryPart.Position).Magnitude
            if d < dist then
                closest = chest
                dist = d
            end
        end
    end

    return closest
end

-- Chest Added
local function onChestAdded(chest)
    if not AutoChestEnabled then return end

    if chest:IsA("Model") and chest.PrimaryPart then
        tweenToPosition(chest.PrimaryPart.Position, function()
            ChestBlacklist[chest] = true
            ChestCount += 1
        end)
    end
end

-- Main Farm
local function startFarm()
    JoinTeam()

    while task.wait(0.2) do
        if not AutoChestEnabled then continue end

        local chest = getClosestChest()

        if chest then
            tweenToPosition(chest.PrimaryPart.Position, function()
                ChestBlacklist[chest] = true
                ChestCount += 1
            end)
        end
    end
end

