--======================
local function moveToCFrame(targetCFrame)
    if character and character:FindFirstChild("HumanoidRootPart") then
        local distance = (targetCFrame.Position - character.HumanoidRootPart.Position).Magnitude
        local walkSpeed = 340
        local timeToReach = distance / walkSpeed

        local goal = {CFrame = targetCFrame}
        local tweenInfo = TweenInfo.new(timeToReach, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut)
        local tween = TweenService:Create(character.HumanoidRootPart, tweenInfo, goal)
        tween:Play()
        tween.Completed:Connect(function()
            print("Teleport Completed to position: " .. tostring(targetCFrame.Position))
        end)
    else
        print("Character or HumanoidRootPart not found!")
    end
end

