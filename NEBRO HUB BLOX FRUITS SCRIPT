-- Session  
local function GetSessionID()  
    local SendHitsToServer = getrenv()._G.SendHitsToServer  
    local CombatThread = getupvalues(SendHitsToServer)[1]  
    return tostring(Player.UserId):sub(2,4)..tostring(CombatThread):sub(11,15)  
