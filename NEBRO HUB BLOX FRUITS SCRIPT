-- ⭐ Equip Fighting Style (مهم)
local function EquipBestStyle()
    for _,style in ipairs(FightingStyles) do
        -- إذا موجود بالشخصية
        if Character:FindFirstChild(style) then
            return
        end
        
        -- إذا موجود بالباكباك
        local tool = Player.Backpack:FindFirstChild(style)
        if tool then
            Humanoid:EquipTool(tool)
            return
        end
    end
end

-- Noclip  
local function Noclip(state)  
    for _,v in pairs(Character:GetDescendants()) do  
        if v:IsA("BasePart") then  
            v.CanCollide = not state  
        end  
    end  
end  

-- Move  
local function MoveTo(pos)  
    Noclip(true)  
    while AutoFarm and (Root.Position - pos).Magnitude > 5 do  
        local dt = RunService.Heartbeat:Wait()  
        local dir = (pos - Root.Position).Unit  
        Root.CFrame += dir * (MoveSpeed * dt)  
    end  
    Noclip(false)  
end  

